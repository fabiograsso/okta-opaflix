# Opaflix AWS Infrastructure Configuration
# Copy this file to config.env and customize values

# =============================================================================
# AWS Settings
# =============================================================================

# AWS region for deployment
AWS_REGION=us-east-1

# S3 bucket name prefix (will be appended with random suffix for uniqueness)
BUCKET_PREFIX=opaflix-sessions

# CloudFormation stack name
STACK_NAME=opaflix

# =============================================================================
# OPA Gateway Configuration
# =============================================================================

# EC2 Instance ID of OPA Gateway (optional if Name is provided)
# Example: i-0123456789abcdef0
GATEWAY_INSTANCE_ID=

# Name tag of OPA Gateway EC2 instance (optional if ID is provided)
# Used to look up the instance if ID is not specified
GATEWAY_INSTANCE_NAME=demoeng-opa-gateway

# =============================================================================
# Certificate Settings (for generate-certificates.sh)
# =============================================================================

# Certificate validity period in days
CERT_VALIDITY_DAYS=3650

# Certificate Common Name (CN) - identifies the application
CERT_CN=opaflix-app

# Certificate Organization (O)
CERT_ORGANIZATION=MyOrganization

# Certificate Organizational Unit (OU)
CERT_OU=Engineering

# Certificate Country (C) - 2-letter code
CERT_COUNTRY=US

# Certificate State/Province (ST)
CERT_STATE=California

# Certificate Locality/City (L)
CERT_LOCALITY=San Francisco

# =============================================================================
# Advanced Settings (usually don't need to change)
# =============================================================================

# CA certificate validity
CA_VALIDITY_DAYS=3650

# Key size in bits
KEY_SIZE=4096

# Output directory for certificates and deployment files
OUTPUT_DIR=./
