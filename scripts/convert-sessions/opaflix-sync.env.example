# OPA Session Sync Service - Environment Configuration
#
# Copy this file to /etc/opaflix/opaflix-sync.env and edit as needed.
# All variables can also be set directly in the environment.
#
# Usage:
#   # With --env-file argument (recommended for testing)
#   python3 opaflix-sync.py --env-file /path/to/this/file.env
#
#   # As systemd service (uses EnvironmentFile directive)
#   sudo systemctl start opaflix-sync

# =============================================================================
# AWS Configuration
# =============================================================================

# AWS region for S3 bucket
AWS_REGION=us-east-1

# S3 bucket name for storing converted sessions (required)
AWS_S3_BUCKET=your-opaflix-bucket

# Optional: S3 key prefix for uploaded files (default: none)
# Files will be uploaded to: s3://bucket/[prefix/]filename.cast
# AWS_S3_PREFIX=sessions

# Optional: AWS credentials (if not using EC2 instance profile)
# If running on EC2 with an IAM instance profile attached, these are not needed.
# The service will automatically use the instance profile credentials.
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key

# =============================================================================
# Directory Configuration
# =============================================================================

# Source directory where OPA writes .asa files
# This is typically configured in the OPA Gateway's LogFolder setting
# Default: /var/log/sft/sessions
# OPA_SOURCE_DIR=/var/log/sft/sessions

# Temporary directory for converted files before S3 upload
# Should be on the same filesystem as source for efficient moves
# Default: /tmp/sessions-temp
# OPA_TEMP_DIR=/tmp/sessions-temp

# =============================================================================
# Processing Options
# =============================================================================

# Maximum time allowed for a single file conversion (in seconds)
# Large RDP sessions may need longer timeouts
# Default: 3600 (1 hour)
# OPA_CONVERSION_TIMEOUT=3600

# Delete source .asa files older than N days (0 = disabled)
# Use this to prevent disk space exhaustion
# Default: 0
# OPA_DELETE_AFTER_DAYS=0

# Delete source .asa file immediately after successful S3 upload
# If true, files are deleted as soon as they're uploaded
# If false (default), files remain until cleanup by OPA_DELETE_AFTER_DAYS
# OPA_DELETE_AFTER_UPLOAD=false

# Upload original .asa source files to S3 for archival/compliance
# Source files are uploaded AFTER successful conversion
# Default: false
# OPA_UPLOAD_SOURCE_FILE=false

# S3 prefix for source files (only used when OPA_UPLOAD_SOURCE_FILE=true)
# Source files will be at: s3://bucket/[prefix/]filename.asa
# Default: empty (uploads to bucket root)
# AWS_S3_SOURCE_PREFIX=source

# =============================================================================
# Memory Management
# =============================================================================

# Maximum number of S3 filenames to cache in memory
# Used to detect already-uploaded files and prevent redundant conversions
# LRU eviction ensures memory stays bounded for very large buckets
# Increase if you have many files and want better duplicate detection
# Default: 50000
# OPA_S3_CACHE_MAX_SIZE=50000

# =============================================================================
# Watchdog Configuration
# =============================================================================

# Delay (in seconds) before processing a new file, to allow writes to complete
# Increase this if files are being processed before they're fully written
# Default: 5.0 (seconds)
# OPA_FILE_SETTLE_DELAY=5.0

# How often to run cleanup of old files (in seconds)
# This also refreshes the S3 file list cache, which is used to:
# - Skip files already uploaded to S3 (avoids redundant conversions)
# - Verify files exist in S3 before deleting old source files
# Default: 86400 (24 hours)
# OPA_CLEANUP_INTERVAL=86400

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
# - DEBUG: Very verbose, includes all operations
# - INFO: Normal operation logging (recommended)
# - WARNING: Only warnings and errors
# - ERROR: Only errors
# Default: INFO
# OPA_LOG_LEVEL=INFO

# Optional: Log file path (in addition to stdout/stderr)
# If not set, logs only go to stdout (captured by systemd journal)
# OPA_LOG_FILE=/var/log/sft/opaflix-sync.log
