<div class="page-header">
  <h1>RDP Sessions</h1>
  <p class="subtitle">Recorded RDP desktop sessions{{#if totalCount}} ({{totalCount}} total){{/if}}</p>
</div>

{{> filterBar sessionType="rdp"}}

{{#if sessions.length}}
{{> sessionTable sessionType="rdp"}}

{{> pagination}}

{{else}}
<div class="empty-state">
  <div class="empty-icon">
    <svg width="64" height="64" viewBox="0 0 20 20" fill="currentColor">
      <!-- Monitor -->
      <rect x="2" y="2" width="16" height="12" rx="1" fill="currentColor"/>
      <rect x="3" y="3" width="14" height="10" fill="none" stroke="white" stroke-width="0.5"/>
      <!-- Base -->
      <rect x="8" y="15" width="4" height="1" fill="currentColor"/>
      <rect x="7" y="16" width="6" height="1" rx="0.5" fill="currentColor"/>
      <!-- Connection arrows -->
      <path d="M 10 7 L 11.5 8.5 M 10 7 L 8.5 8.5 M 10 10 L 11.5 8.5 M 10 10 L 8.5 8.5" stroke="white" stroke-width="0.8" stroke-linecap="round"/>
    </svg>
  </div>
  {{#if hasActiveFilters}}
  <h2>No Matching Sessions</h2>
  <p>No RDP sessions match your search criteria.</p>
  <button type="button" id="clearFiltersEmptyBtn" class="btn btn-primary">Clear All Filters</button>
  {{else}}
  <h2>No RDP Sessions Found</h2>
  <p>There are no recorded RDP sessions in the storage.</p>
  {{/if}}
</div>
{{/if}}

{{> advancedSearchModal}}

<script src="{{asset '/js/sessionList.js'}}"></script>
<script id="sessionListConfig" type="application/json">
{
  "sortField": {{{json sortField}}},
  "sortOrder": {{{json sortOrder}}},
  "sessionType": "rdp"
}
</script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  var configEl = document.getElementById('sessionListConfig');
  var config = JSON.parse(configEl.textContent);
  initSessionList({
    sortField: config.sortField || 'timestamp',
    sortOrder: config.sortOrder || 'desc',
    sessionType: config.sessionType
  });
});
</script>
